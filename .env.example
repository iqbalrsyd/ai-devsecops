# ──────────────────────────────────────────────
# AI DevSecOps Security Assistant
# ──────────────────────────────────────────────

# --- Database ---
DATABASE_URL=postgres://postgres:postgres@postgres:5432/ai_devsecops
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=ai_devsecops
DATABASE_SSLMODE=disable

# --- Redis ---
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Backend ---
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
JWT_SECRET=change-me-in-production
JWT_ACCESS_DURATION=15m
JWT_REFRESH_DURATION=168h
ENCRYPTION_KEY=
AI_SERVICE_URL=http://ai-service:8000

# --- AI Service ---
HOST=0.0.0.0
PORT=8000
APP_NAME=AI DevSecOps Security Assistant
DEBUG=true
BACKEND_API_URL=http://backend:8080/api/v1

# --- LLM Providers (at least one required) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_PROVIDER=openrouter
LLM_MODEL=deepseek/deepseek-v4-flash
LLM_REQUEST_TIMEOUT=120

# --- LangSmith (optional) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-devsecops-assistant

# --- Frontend ---
VITE_API_URL=http://localhost:8080/api/v1