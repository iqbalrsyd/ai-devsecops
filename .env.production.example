# ──────────────────────────────────────────────
# AI DevSecOps Security Assistant
# Production Environment Template
# ──────────────────────────────────────────────
# COPY THIS FILE TO .env AND FILL IN ALL VALUES
# DO NOT COMMIT .env TO GIT
# ──────────────────────────────────────────────

# --- Database ---
# Generate: openssl rand -hex 16
POSTGRES_PASSWORD=__GENERATE_POSTGRES_PASSWORD__
DATABASE_USER=ai_devsecops
DATABASE_NAME=ai_devsecops
DATABASE_SSLMODE=disable

# --- Backend ---
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
# Generate: openssl rand -hex 32
JWT_SECRET=__GENERATE_JWT_SECRET__
JWT_ACCESS_DURATION=15m
JWT_REFRESH_DURATION=168h
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=__GENERATE_ENCRYPTION_KEY__
AI_SERVICE_URL=http://ai-service:8000
# Comma-separated list of allowed origins (no trailing slash)
CORS_ALLOWED_ORIGINS=https://app.iqbalhidayatrasyad.blog

# --- AI Service ---
HOST=0.0.0.0
PORT=8000
APP_NAME=AI DevSecOps Security Assistant
DEBUG=false
BACKEND_API_URL=http://backend:8080/api/v1

# --- LLM Providers (at least one required) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=__FILL_IN_OPENROUTER_KEY__
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_PROVIDER=openrouter
LLM_MODEL=deepseek/deepseek-v4-flash
LLM_REQUEST_TIMEOUT=120

# --- LangSmith (optional) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# --- GitHub (optional, for GitHub integration features) ---
GITHUB_TOKEN=

# --- Frontend (DI-BAKE SAAT BUILD, bukan runtime!) ---
# Set this BEFORE building frontend
VITE_API_URL=https://app.iqbalhidayatrasyad.blog/api/v1
